# --- Terragrunt & Terraform ---
# Ignore the massive cache and stack metadata
**/.terragrunt-cache/
**/.terragrunt-stack/
**/.terraform/
.terraform.lock.hcl

# Ignore all state files and backups
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info

# Ignore generated plan files (standard name for Terragrunt out-dir)
*.tfplan
tfplan.tfplan

# --- Variables & Secrets ---
# Ignore ALL variables files (prevent accidental secret leaks)
*.tfvars
*.tfvars.json

# If you use .env files or direnv
.env
.envrc
.secrets

# --- Kubernetes Specific ---
# Ignore local kubeconfigs or credentials downloaded during tasks
**/kubeconfig
**/.kube/
.certs/
*.pem
*.crt

# --- System & IDE ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log
crash.log